---
import "../styles/global.css";
import MainLayout from "../layouts/MainLayout.astro";
const semuaAgenda = [
  {
    id: 1,
    title: "Kopi Darat & Rolling City",
    date: "Sabtu, 28 Juni 2026",
    time: "06:00 WIB",
    startPoint: "Alun-Alun Kota",
    distance: "40 Km",
    elevation: "150 m",
    speed: "22-25 km/h",
    difficulty: "Santai",
    badgeColor: "bg-emerald-500/10 text-emerald-400 border-emerald-500/40",
    image: "/images/event-kopdar.jpg",
    description:
      "Gowes santai keliling kota untuk mempererat silaturahmi. Rute flat, cocok untuk semua jenis sepeda. Diakhiri dengan sarapan bareng.",
  },
  {
    id: 2,
    title: "Satur-Day Out Endurance",
    date: "Minggu, 29 Juni 2026",
    time: "05:30 WIB",
    startPoint: "Basecamp Cycling Club",
    distance: "80 Km",
    elevation: "450 m",
    speed: "28-30 km/h",
    difficulty: "Medium",
    badgeColor: "bg-amber-500/10 text-amber-400 border-amber-500/40",
    image: "/images/event-saturday.jpg",
    description:
      "Latihan endurance mingguan bagi yang ingin meningkatkan power dan stamina. Disarankan menggunakan Road Bike atau Gravel Bike.",
  },
  {
    id: 3,
    title: "King of Mountain - Pacet",
    date: "Minggu, 5 Juli 2026",
    time: "06:00 WIB",
    startPoint: "Rest Area Tikungan Gajah",
    distance: "60 Km",
    elevation: "1,200 m",
    speed: "Menyesuaikan",
    difficulty: "Kencang",
    badgeColor: "bg-red-500/10 text-red-400 border-red-500/40",
    image: "/images/event-pacet.jpg",
    description:
      "Menu tanjakan murni bagi para pelari tanjakan (climber). Pastikan rasio gigi sepeda Anda aman dan kondisi fisik prima.",
  },
];
---

{
  /* 2. Bungkus seluruh sisa konten dengan MainLayout dan kirimkan title yang sesuai */
}
<MainLayout title="Agenda Gowes">
  {/* HEADER PAGE */}
  <header
    class="bg-zinc-900 border-b border-zinc-800 py-12 md:py-16 bg-[url('/images/asphalt-texture.png')] bg-cover bg-blend-overlay"
  >
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span
        class="text-lime-400 text-xs font-bold tracking-widest uppercase block mb-2"
        >Join The Ride</span
      >
      <h1
        class="text-3xl md:text-5xl font-black uppercase italic tracking-tight"
      >
        Kalender Kegiatan Club
      </h1>
      <p class="mt-3 text-sm md:text-base text-zinc-400 max-w-xl mx-auto">
        Pilih rute gowes yang sesuai dengan kemampuan dan jenis sepeda Anda.
        Semua event terbuka untuk anggota resmi maupun partisipan baru.
      </p>
    </div>
  </header>

  {/* MAIN CONTENT: DAFTAR AGENDA */}
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="space-y-8">
      {
        semuaAgenda.map((agenda) => (
          <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden flex flex-col md:flex-row hover:border-zinc-700 transition duration-300 shadow-xl">
            {/* Sisi Kiri/Atas: Gambar Event */}
            <div class="w-full md:w-2/5 h-48 md:h-auto relative bg-zinc-800 overflow-hidden">
              <img
                src={agenda.image}
                alt={agenda.title}
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
              />
            </div>

            {/* Sisi Kanan/Bawah: Konten Detail */}
            <div class="p-6 md:p-8 flex-1 flex flex-col justify-between">
              <div>
                <div class="flex items-center justify-between gap-4">
                  <span class="text-xs font-bold text-lime-400 tracking-wider uppercase">
                    {agenda.date}
                  </span>
                  <span
                    class={`border ${agenda.badgeColor} text-[10px] font-black px-2.5 py-0.5 rounded-full uppercase tracking-wider`}
                  >
                    {agenda.difficulty}
                  </span>
                </div>

                <h2 class="text-xl md:text-2xl font-black uppercase italic text-zinc-100 mt-2 tracking-wide">
                  {agenda.id}. {agenda.title}
                </h2>

                <p class="text-zinc-400 text-sm mt-3 leading-relaxed">
                  {agenda.description}
                </p>
              </div>

              {/* Metrik/Informasi Teknis Rute */}
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-6 pt-6 border-t border-zinc-800 text-xs">
                <div>
                  <p class="text-zinc-500 uppercase tracking-wider font-semibold">
                    Jam Kumpul
                  </p>
                  <p class="text-zinc-200 font-bold mt-0.5">{agenda.time}</p>
                </div>
                <div>
                  <p class="text-zinc-500 uppercase tracking-wider font-semibold">
                    Titik Start
                  </p>
                  <p
                    class="text-zinc-200 font-bold mt-0.5 truncate max-w-[150px]"
                    title={agenda.startPoint}
                  >
                    {agenda.startPoint}
                  </p>
                </div>
                <div>
                  <p class="text-zinc-500 uppercase tracking-wider font-semibold">
                    Jarak / Elevasi
                  </p>
                  <p class="text-zinc-200 font-bold mt-0.5">
                    {agenda.distance} / {agenda.elevation}
                  </p>
                </div>
                <div>
                  <p class="text-zinc-500 uppercase tracking-wider font-semibold">
                    Target Speed
                  </p>
                  <p class="text-zinc-200 font-bold mt-0.5">{agenda.speed}</p>
                </div>
              </div>

              {/* Tombol Aksi */}
              <div class="mt-6 flex justify-end">
                <button class="w-full sm:w-auto bg-zinc-800 hover:bg-lime-400 hover:text-zinc-950 border border-zinc-700 hover:border-lime-400 text-zinc-200 font-bold px-5 py-2.5 rounded-xl text-xs uppercase tracking-wider transition active:scale-95">
                  Ikut Acara Ini
                </button>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </main>
</MainLayout>
