---
import "../styles/global.css";
import MainLayout from "../layouts/MainLayout.astro";

// Data dokumentasi foto gowes komunitas
const dokumentasiFoto = [
    {
        id: 1,
        title: "Peloton Rolling City",
        category: "Event",
        image: "/images/hero-peloton.jpg",
        description: "Keseruan gowes keliling kota bersama seluruh anggota.",
    },
    {
        id: 2,
        title: "Sarapan Bubur Selepas Km 40",
        category: "Social",
        image: "/images/event-kopdar.jpg",
        description:
            "Budaya wajib club: isi kembali amunisi setelah gowes santai.",
    },
    {
        id: 3,
        title: "Tanjakan King of Pacet",
        category: "Climb",
        image: "/images/event-pacet.jpg",
        description:
            "Siksaan tanjakan berbuah pemandangan indah lereng gunung.",
    },
    {
        id: 4,
        title: "Satur-Day Out Peloton",
        category: "Event",
        image: "/images/event-saturday.jpg",
        description: "Formasi rapi pleton saat melibas jalur antar kota.",
    },
    {
        id: 5,
        title: "Custom Build Gravel Bike",
        category: "Bike Check",
        image: "/images/event-saturday.jpg", // Ganti dengan foto sepeda anggota jika ada
        description:
            "Sepeda rakitan tangguh siap melibas segala medan makadam.",
    },
    {
        id: 6,
        title: "View Pagi Jalur Lintas Selatan",
        category: "Scenery",
        image: "/images/hero-peloton.jpg", // Ganti dengan foto lanskap pemandangan
        description:
            "Mengejar sunrise terbaik di sepanjang pesisir pantai selatan.",
    },
];
---

<MainLayout title="Galeri Foto - Cycling Club">
    <html lang="id">
        <header
            class="bg-zinc-900 border-b border-zinc-800 py-12 md:py-16 bg-[url('/images/asphalt-texture.png')] bg-cover bg-blend-overlay"
        >
            <div class="max-w-4xl mx-auto px-4 text-center">
                <span
                    class="text-lime-400 text-xs font-bold tracking-widest uppercase block mb-2"
                    >Captured Moments</span
                >
                <h1
                    class="text-3xl md:text-5xl font-black uppercase italic tracking-tight"
                >
                    Kilas Balik Dokumentasi
                </h1>
                <p
                    class="mt-3 text-sm md:text-base text-zinc-400 max-w-xl mx-auto"
                >
                    Arsip dokumentasi keseruan gowes bersama, pemandangan rute
                    terindah, hingga pameran rakitan sepeda komponen milik
                    anggota.
                </p>
            </div>
        </header>

        <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
                {
                    dokumentasiFoto.map((foto) => (
                        <div class="break-inside-avoid bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden hover:border-zinc-700 transition duration-300 shadow-xl group relative">
                            <div class="overflow-hidden bg-zinc-800">
                                <img
                                    src={foto.image}
                                    alt={foto.title}
                                    class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                                    loading="lazy"
                                />
                            </div>

                            <div class="p-5 bg-gradient-to-t from-zinc-950 via-zinc-900/90 to-zinc-900/50 border-t border-zinc-800/60">
                                <div class="flex items-center justify-between gap-4 mb-1.5">
                                    <span class="text-[10px] font-black uppercase tracking-widest text-lime-400">
                                        {foto.category}
                                    </span>
                                </div>

                                <h2 class="text-base font-bold text-zinc-100 tracking-wide">
                                    {foto.title}
                                </h2>

                                <p class="text-zinc-400 text-xs mt-1 leading-relaxed hidden group-hover:block transition-all duration-300">
                                    {foto.description}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </main>
    </html>
</MainLayout>
