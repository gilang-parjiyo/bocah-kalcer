---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Tips & Tool Box">

  {/* HEADER PAGE */}
  <header class="bg-zinc-900 border-b border-zinc-800 py-12 md:py-16 bg-[url('/images/asphalt-texture.png')] bg-cover bg-blend-overlay">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="text-lime-400 text-xs font-bold tracking-widest uppercase block mb-2">Mechanic Corner</span>
      <h1 class="text-3xl md:text-5xl font-black uppercase italic tracking-tight">Tips & Tool Box</h1>
      <p class="mt-3 text-sm md:text-base text-zinc-400 max-w-xl mx-auto">
        Kalkulator teknis sederhana untuk membantu Anda mengatur rasio gigi ideal sebelum menaklukkan tanjakan ekstrem atau memilih ukuran sepeda yang pas.
      </p>
    </div>
  </header>

  <main class="max-w-4xl mx-auto px-4 py-12 space-y-12">
    
    {/* FITUR 1: KALKULATOR RASIO GIGI */}
    <section class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 md:p-8 shadow-xl">
      <div class="flex items-center gap-3 mb-6">
        <div class="p-2 bg-lime-400/10 text-lime-400 rounded-lg">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0 0 15 0m-15 0a7.5 7.5 0 1 1 15 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077 1.41-.513m14.095-5.13 1.41-.513M5.106 17.785l1.15-.827m11.379-8.16 1.15-.827M8.14 21.27l.707-1.03m6.95-10.16.707-1.03M12 3v1.5m0 15V21m4.743-10l-1.149-.827M6.405 17.785l-1.15-.827m11.379 8.16-1.15-.827M12 12l9 9m-9-9-9 9" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-black uppercase italic tracking-wide text-zinc-100">Kalkulator Rasio Gigi (Climbing Ratio)</h2>
          <p class="text-xs text-zinc-400">Hitung seberapa ringan gigi sepeda Anda untuk medan menanjak.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-zinc-400 mb-2">Chainring Depan (Jumlah Gigi)</label>
          <input type="number" id="chainring" value="34" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 font-bold focus:border-lime-400 focus:outline-none" />
          <span class="text-[10px] text-zinc-500 mt-1 block">*Ukuran standar compact road bike biasanya 34T atau 50T.</span>
        </div>
        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-zinc-400 mb-2">Sprocket Belakang / Cassette (Gigi Terbesar)</label>
          <input type="number" id="sprocket" value="34" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 font-bold focus:border-lime-400 focus:outline-none" />
          <span class="text-[10px] text-zinc-500 mt-1 block">*Makin besar ukuran sprocket belakang, tanjakan terasa makin ringan.</span>
        </div>
      </div>

      <div class="mt-6 bg-zinc-950 border border-zinc-800/80 rounded-xl p-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div>
          <p class="text-xs text-zinc-500 uppercase font-semibold tracking-wider">Hasil Gear Ratio Anda</p>
          <p class="text-3xl font-black text-lime-400 mt-1" id="ratio-output">1.00</p>
        </div>
        <div class="text-xs text-zinc-400 sm:max-w-md text-left sm:text-right" id="ratio-status">
          Rasio 1.00 atau di bawahnya sangat ideal dan aman untuk melibas tanjakan terjal seperti Pacet tanpa menyiksa lutut.
        </div>
      </div>
    </section>

    {/* FITUR 2: BIKE SIZE FINDER */}
    <section class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 md:p-8 shadow-xl">
      <div class="flex items-center gap-3 mb-6">
        <div class="p-2 bg-lime-400/10 text-lime-400 rounded-lg">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2Z" />
          </svg>
        </div>
        <div>
          <h2 class="text-xl font-black uppercase italic tracking-wide text-zinc-100">Kalkulator Ukuran Bingkai (Bike Fitting Size)</h2>
          <p class="text-xs text-zinc-400">Temukan ukuran frame Road/Gravel Bike yang pas berdasarkan tinggi badan Anda.</p>
        </div>
      </div>

      <div class="max-w-xs">
        <label class="block text-xs font-bold uppercase tracking-wider text-zinc-400 mb-2">Tinggi Badan Anda (cm)</label>
        <input type="number" id="height" value="170" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-3 text-zinc-100 font-bold focus:border-lime-400 focus:outline-none" />
      </div>

      <div class="mt-6 bg-zinc-950 border border-zinc-800/80 rounded-xl p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <p class="text-xs text-zinc-500 uppercase font-semibold tracking-wider">Rekomendasi Ukuran Frame</p>
          <p class="text-3xl font-black text-lime-400 mt-1" id="size-output">M (52-54)</p>
        </div>
        <div class="text-xs text-zinc-400 flex items-center">
          <p id="size-note">Ukuran ini memberikan kenyamanan optimal guna meminimalisir risiko cedera punggung dan lutut saat gowes jarak jauh.</p>
        </div>
      </div>
    </section>

  </main>
</MainLayout>

{/* LOGIKA INTERAKTIF JAVASCRIPT */}
<script>
  // Logika 1: Kalkulator Rasio Gigi
  const chainringInput = document.getElementById('chainring') as HTMLInputElement;
  const sprocketInput = document.getElementById('sprocket') as HTMLInputElement;
  const ratioOutput = document.getElementById('ratio-output');
  const ratioStatus = document.getElementById('ratio-status');

  function calculateRatio() {
    if (chainringInput && sprocketInput && ratioOutput && ratioStatus) {
      const chainring = parseFloat(chainringInput.value);
      const sprocket = parseFloat(sprocketInput.value);
      
      if (chainring > 0 && sprocket > 0) {
        const ratio = chainring / sprocket;
        ratioOutput.innerText = ratio.toFixed(2);

        if (ratio <= 1.0) {
          ratioStatus.innerText = "Rasio super ringan! Sangat ideal dan aman untuk melibas tanjakan terjal pegunungan tanpa menyiksa lutut.";
        } else if (ratio > 1.0 && ratio <= 1.3) {
          ratioStatus.innerText = "Rasio medium. Cocok untuk tanjakan bervariasi (rolling hills) atau rute flat dengan tanjakan pendek.";
        } else {
          ratioStatus.innerText = "Rasio berat (gigi balap). Sempurna untuk kecepatan tinggi di jalan flat, tapi butuh power ekstra besar jika dipakai menanjak.";
        }
      }
    }
  }

  // Logika 2: Kalkulator Ukuran Sepeda
  const heightInput = document.getElementById('height') as HTMLInputElement;
  const sizeOutput = document.getElementById('size-output');
  const sizeNote = document.getElementById('size-note');

  function calculateSize() {
    if (heightInput && sizeOutput && sizeNote) {
      const height = parseFloat(heightInput.value);

      if (height < 160) {
        sizeOutput.innerText = "XS (47-49)";
        sizeNote.innerText = "Cocok untuk postur tubuh lincah, memberikan kendali handling kemudi sepeda yang sangat mantap.";
      } else if (height >= 160 && height < 170) {
        sizeOutput.innerText = "S (50-52)";
        sizeNote.innerText = "Ukuran seimbang untuk fleksibilitas berkendara santai maupun agresif di jalan aspal.";
      } else if (height >= 170 && height < 180) {
        sizeOutput.innerText = "M (52-54)";
        sizeNote.innerText = "Ukuran paling pas untuk kenyamanan optimal guna meminimalisir risiko cedera punggung saat gowes jarak jauh.";
      } else if (height >= 180 && height < 188) {
        sizeOutput.innerText = "L (54-56)";
        sizeNote.innerText = "Disarankan untuk pengendara berpostur tinggi demi jangkauan tangan (*reach*) yang proporsional.";
      } else {
        sizeOutput.innerText = "XL (56-58+)";
        sizeNote.innerText = "Ukuran bingkai maksimal, disarankan melakukan konsultasi profesional bike fitting lanjutan.";
      }
    }
  }

  // Pasang Event Listener agar kalkulator otomatis berjalan saat angka diketik
  chainringInput?.addEventListener('input', calculateRatio);
  sprocketInput?.addEventListener('input', calculateRatio);
  heightInput?.addEventListener('input', calculateSize);
</script>