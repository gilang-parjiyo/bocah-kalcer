---
import MainLayout from '../../layouts/MainLayout.astro';

export async function getStaticPaths({ paginate }) {
  // 1. Tambahkan properti 'kategori' pada setiap data foto Anda
  const daftarFoto = [
    { id: 1, url: '/images/galeri/foto1.webp', alt: 'Gowes Pagi Bocah Kalcer', kategori: 'event' },
    { id: 2, url: '/images/galeri/foto2.webp', alt: 'Tanjakan Pacet Cruel', kategori: 'rute' },
    { id: 3, url: '/images/galeri/foto3.webp', alt: 'Rest Area Ceten', kategori: 'rute' },
    { id: 4, url: '/images/galeri/foto4.webp', alt: 'Morning Sprint Asik', kategori: 'event' },
    { id: 5, url: '/images/galeri/foto5.webp', alt: 'Kopi Macet Kalcer', kategori: 'sepeda' },
    { id: 6, url: '/images/galeri/foto6.webp', alt: 'Peloton Bocah Kalcer', kategori: 'event' },
    { id: 7, url: '/images/galeri/foto7.webp', alt: 'Jersey Baru Mantap', kategori: 'sepeda' },
    { id: 8, url: '/images/galeri/foto8.webp', alt: 'Rolling Hills Indah', kategori: 'rute' },
    { id: 9, url: '/images/galeri/foto9.webp', alt: 'Mekanik Bongkar Sendiri', kategori: 'sepeda' },
    { id: 10, url: '/images/galeri/foto10.webp', alt: 'Gowes Tipis Senja', kategori: 'rute' },
    { id: 11, url: '/images/galeri/foto11.webp', alt: 'Ban Bocor Solidaritas', kategori: 'event' },
    { id: 12, url: '/images/galeri/foto12.webp', alt: 'Sarapan Bubur Kelar Gowes', kategori: 'event' },
  ];

  // Karena Astro mengonfigurasi rute statis di getStaticPaths, kita perlu memecah paginasi untuk semua kategori
  // Agar tombol filter bekerja secara instan tanpa memotong total halaman, kita kirimkan seluruh daftar
  return paginate(daftarFoto, { pageSize: 12 }); // Naikkan pageSize jika ingin mematikan paginasi saat filter aktif, atau biarkan 9.
}

const { page } = Astro.props;

// 2. Ambil parameter filter dari URL (Client-side logic nanti akan membaca ini)
// Untuk rute statis murni Astro, kita akan memfilter item menggunakan JavaScript di browser agar lebih responsif.
---

<MainLayout title={`Galeri Foto - Halaman ${page.currentPage}`}>
  <main class="max-w-6xl mx-auto px-4 py-12">
    {/* TOMBOL FILTER KATEGORI */}
    <div class="flex flex-wrap items-center justify-center gap-3 mb-10">
      <button
        data-filter="all"
        class="filter-btn px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider bg-lime-400 text-zinc-950 transition border border-transparent"
      >
        Semua Foto
      </button>
      <button
        data-filter="rute"
        class="filter-btn px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider bg-zinc-900 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-850 transition border border-zinc-800"
      >
        🗺️ Rute
      </button>
      <button
        data-filter="event"
        class="filter-btn px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider bg-zinc-900 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-850 transition border border-zinc-800"
      >
        🏁 Event
      </button>
      <button
        data-filter="sepeda"
        class="filter-btn px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider bg-zinc-900 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-850 transition border border-zinc-800"
      >
        🚲 Sepeda
      </button>
    </div>
    {/* HEADER HALAMAN */}
    <div class="text-center mb-12">
      <span
        class="text-lime-400 text-xs font-bold tracking-widest uppercase block mb-2"
        >Our Moments</span
      >
      <h1
        class="text-3xl md:text-5xl font-black uppercase italic tracking-tight"
      >
        Dokumentasi Kegiatan
      </h1>
      <p class="text-sm text-zinc-400 mt-2">
        Halaman {page.currentPage} dari {page.lastPage}
      </p>
    </div>

    {/* GRID FOTO (MAKSIMAL 9 ITEM) */}
 {/* GRID FOTO */}
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6" id="gallery-grid">
      {page.data.map((foto) => (
        <div 
          data-category={foto.kategori} 
          class="gallery-item bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden shadow-xl group transition-all duration-300"
        >
          <div class="aspect-video w-full bg-zinc-950 overflow-hidden relative">
            <img 
              src={foto.url} 
              alt={foto.alt} 
              loading="lazy"
              class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
            />
          </div>
          <div class="p-4">
            <p class="text-xs font-semibold text-zinc-350 tracking-wide">{foto.alt}</p>
          </div>
        </div>
      ))}
    </div>

    {/* NAVIGASI PAGINASI (PREVIOUS / NEXT PAGE) */}
    <div
      class="flex items-center justify-center gap-4 mt-12 pt-6 border-t border-zinc-900"
    >
      {/* Tombol Previous */}
      {
        page.url.prev ? (
          <a
            href={page.url.prev}
            class="inline-flex items-center gap-2 bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider text-zinc-300 transition"
          >
            ← Prev
          </a>
        ) : (
          <button
            disabled
            class="inline-flex items-center gap-2 bg-zinc-950 border border-zinc-900 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider text-zinc-600 cursor-not-allowed"
          >
            ← Prev
          </button>
        )
      }

      {/* Indikator Halaman Aktif */}
      <span
        class="text-xs font-mono font-bold text-lime-400 bg-lime-400/10 px-3 py-2 rounded-lg border border-lime-400/20"
      >
        {page.currentPage} / {page.lastPage}
      </span>

      {/* Tombol Next */}
      {
        page.url.next ? (
          <a
            href={page.url.next}
            class="inline-flex items-center gap-2 bg-zinc-900 hover:bg-zinc-800 border border-zinc-800 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider text-zinc-300 transition"
          >
            Next →
          </a>
        ) : (
          <button
            disabled
            class="inline-flex items-center gap-2 bg-zinc-950 border border-zinc-900 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider text-zinc-600 cursor-not-allowed"
          >
            Next →
          </button>
        )
      }
    </div>
  </main>
</MainLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.gallery-item') as NodeListOf<HTMLElement>;

  buttons.forEach(button => {
    button.addEventListener('click', () => {
      const filterValue = button.getAttribute('data-filter');

      // 1. Ubah styling tombol aktif
      buttons.forEach(btn => {
        btn.classList.remove('bg-lime-400', 'text-zinc-950');
        btn.classList.add('bg-zinc-900', 'text-zinc-400', 'border-zinc-800');
      });
      button.classList.remove('bg-zinc-900', 'text-zinc-400', 'border-zinc-800');
      button.classList.add('bg-lime-400', 'text-zinc-950');

      // 2. Logika Menyembunyikan / Menampilkan Foto dengan Animasi Smooth
      items.forEach(item => {
        const itemCategory = item.getAttribute('data-category');

        if (filterValue === 'all' || filterValue === itemCategory) {
          item.style.display = 'block';
          setTimeout(() => {
            item.style.opacity = '1';
            item.style.transform = 'scale(1)';
          }, 10);
        } else {
          item.style.opacity = '0';
          item.style.transform = 'scale(0.95)';
          setTimeout(() => {
            item.style.display = 'none';
          }, 300); // Sinkron dengan durasi animasi CSS
        }
      });
    });
  });
</script>
