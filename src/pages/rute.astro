---
import "../styles/global.css";
import MainLayout from "../layouts/mainLayout.astro";

// Data rute andalan komunitas sepeda
const daftarRute = [
    {
        id: 1,
        name: "Looping Jalur Lingkar Kota",
        type: "Road / Flat",
        distance: "35 Km",
        elevation: "80 m",
        suitability: "Semua Sepeda",
        difficulty: "Santai",
        badgeColor: "bg-emerald-500/10 text-emerald-400 border-emerald-500/40",
        image: "/images/event-kopdar.jpg",
        gpxLink: "/files/loop-kota.gpx",
        description:
            "Rute aspal mulus mengelilingi jalur lingkar luar kota. Sangat minim persimpangan besar, menjadikannya jalur favorit untuk latihan peloton malam hari (Night Ride) atau gowes santai subuh.",
    },
    {
        id: 2,
        name: "Tanjakan Eksotis Pacet - Claket",
        type: "Road / Climbing",
        distance: "60 Km",
        elevation: "1,250 m",
        suitability: "Road Bike / Gravel",
        difficulty: "Kencang",
        badgeColor: "bg-red-500/10 text-red-400 border-red-500/40",
        image: "/images/event-pacet.jpg",
        gpxLink: "/files/pacet-claket.gpx",
        description:
            "Jalur legendaris bagi para pencinta elevasi. Menyuguhkan pemandangan lereng gunung yang indah namun dengan siksaan tanjakan konstan berkisar antara 8% hingga 18% di beberapa titik ikonik.",
    },
    {
        id: 3,
        name: "Gravel Rolling Hills Sawangan",
        type: "Gravel / Off-road Light",
        distance: "45 Km",
        elevation: "510 m",
        suitability: "Gravel / MTB",
        difficulty: "Medium",
        badgeColor: "bg-amber-500/10 text-amber-400 border-amber-500/40",
        image: "/images/event-saturday.jpg",
        gpxLink: "/files/gravel-sawangan.gpx",
        description:
            "Kombinasi 60% jalan makadam/tanah padat dan 40% aspal pedesaan. Melewati perbukitan hijau, area persawahan, dan beberapa jembatan gantung kecil yang sangat estetik.",
    },
];
---

{
    (
        <MainLayout title="Rute Favorit - Cycling Club">
            <html lang="id">
                <header class="bg-zinc-900 border-b border-zinc-800 py-12 md:py-16 bg-[url('/images/asphalt-texture.png')] bg-cover bg-blend-overlay">
                    <div class="max-w-4xl mx-auto px-4 text-center">
                        <span class="text-lime-400 text-xs font-bold tracking-widest uppercase block mb-2">
                            Explore Tracks
                        </span>
                        <h1 class="text-3xl md:text-5xl font-black uppercase italic tracking-tight">
                            Katalog Rute Andalan
                        </h1>
                        <p class="mt-3 text-sm md:text-base text-zinc-400 max-w-xl mx-auto">
                            Daftar jalur gowes yang sering dilalui oleh
                            komunitas. Lengkap dengan estimasi jarak, elevasi,
                            dan file koordinat GPS yang siap Anda unduh.
                        </p>
                    </div>
                </header>

                <main class="max-w-5xl mx-auto px-4 py-12">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {daftarRute.map((rute) => (
                            <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden flex flex-col justify-between hover:border-zinc-700 transition duration-300 shadow-2xl group">
                                <div>
                                    <div class="h-52 w-full bg-zinc-800 overflow-hidden relative">
                                        <img
                                            src={rute.image}
                                            alt={rute.name}
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                        />
                                        <div class="absolute top-4 left-4 flex gap-2">
                                            <span class="bg-zinc-950/80 backdrop-blur border border-zinc-700 text-zinc-300 text-[10px] font-bold px-2.5 py-1 rounded-md uppercase">
                                                {rute.type}
                                            </span>
                                        </div>
                                        <div class="absolute top-4 right-4">
                                            <span
                                                class={`border ${rute.badgeColor} text-[10px] font-black px-2.5 py-1 rounded-full uppercase tracking-wider`}
                                            >
                                                {rute.difficulty}
                                            </span>
                                        </div>
                                    </div>

                                    <div class="p-6">
                                        <h2 class="text-xl font-black uppercase italic tracking-wide text-zinc-100 group-hover:text-lime-400 transition">
                                            {rute.name}
                                        </h2>
                                        <p class="text-xs text-zinc-500 mt-1 font-semibold">
                                            Kategori Sepeda: {rute.suitability}
                                        </p>

                                        <p class="text-zinc-400 text-sm mt-4 leading-relaxed line-clamp-3">
                                            {rute.description}
                                        </p>
                                    </div>
                                </div>

                                <div class="p-6 pt-0">
                                    <div class="grid grid-cols-2 gap-4 py-4 my-2 border-t border-b border-zinc-800 text-xs">
                                        <div>
                                            <p class="text-zinc-500 uppercase tracking-wider font-semibold">
                                                Total Jarak
                                            </p>
                                            <p class="text-lime-400 font-bold text-lg mt-0.5">
                                                {rute.distance}
                                            </p>
                                        </div>
                                        <div>
                                            <p class="text-zinc-500 uppercase tracking-wider font-semibold">
                                                Elevation Gain
                                            </p>
                                            <p class="text-zinc-200 font-bold text-lg mt-0.5">
                                                {rute.elevation}
                                            </p>
                                        </div>
                                    </div>

                                    <div class="mt-4">
                                        <a
                                            href={rute.gpxLink}
                                            download
                                            class="w-full flex items-center justify-center gap-2 bg-zinc-800 hover:bg-lime-400 hover:text-zinc-950 border border-zinc-700 hover:border-lime-400 text-zinc-200 font-bold px-4 py-3 rounded-xl text-xs uppercase tracking-wider transition active:scale-95"
                                        >
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke-width="2"
                                                stroke="currentColor"
                                                class="w-4 h-4"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
                                                />
                                            </svg>
                                            Unduh File GPX (Peta)
                                        </a>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </main>
            </html>
        </MainLayout>
    )
}
